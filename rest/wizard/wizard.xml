<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id ="children_tree" model = "ir.ui.view">
            <field name = "name">children.tree</field>
            <field name = "model">ir.model.fields</field>
            <field name = "priority">100</field>
            <field name = "arch" type = "xml">
                <tree name = "WKAKAKK">
                    <field name = "name"/>
                    <field name = "ttype"/>
                    <field name = "relation"/>
                    <field name = "id" invisible = "1"/>
                    <field name = "button_domain" invisible = "1"/>
                    <field name = "path"/>
                    <button name = "children_show" type = "object" string ="Manage Children" class = "oe_highlight"
                    attrs="{'invisible':[('button_domain','=',False)]}"
                            context = "{'path' : path}"
                    />
                </tree>
            </field>
        </record>

        <record model = "ir.actions.server" id = "action_manage_children" >
            <field name="name">Save Selected Fields</field>
           <field name="model_id" ref="base.model_ir_model_fields"/>
           <field name="binding_model_id" ref="base.model_ir_model_fields"/>
            <field name="binding_view_types">list</field>
           <field name="state">code</field>
           <field name="code">
               action = records.save_fields()
           </field>
        </record>

    </data>
</odoo>